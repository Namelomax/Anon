# Скопируйте в .env.local и при необходимости измените.

# URL Python-бэкенда (server.py с эндпоинтом /anonymize-file).
# Локальный тест: ваш server.py на 127.0.0.1:8000 (LLM указывает на LM Studio).
ANONYMIZER_BACKEND_URL=http://127.0.0.1:8000

# Bearer-токен бэкенда. Для локального теста не нужен (оставьте пустым).
# Для удалённого бэкенда (JupyterHub-прокси) укажите токен здесь — он
# подставляется на сервере и не попадает в браузер.
ANONYMIZER_BACKEND_KEY=
